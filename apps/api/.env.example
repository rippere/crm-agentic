SUPABASE_URL=https://your-project.supabase.co
# Supabase Session-mode pooler URL (postgresql+asyncpg://...). Railway requires
# the pooler URL because Railway egress IPs may not be whitelisted on direct DB.
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SECRET_KEY=your-random-secret-key-32-chars-min
ANTHROPIC_API_KEY=sk-ant-...
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_HITL_CHANNEL=general
HUNTER_API_KEY=
