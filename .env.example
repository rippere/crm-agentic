# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker Compose: leave as-is — the compose file overrides this to the postgres service.
# Supabase direct: Settings → Database → Connection String (Transaction mode, port 6543)
DATABASE_URL=postgresql+asyncpg://postgres:devpass@localhost:5432/crmdb

# Password for the postgres container (docker-compose only)
POSTGRES_PASSWORD=devpass

# ─── FastAPI ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret

NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI ───────────────────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google / Gmail OAuth ─────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Add redirect URI: http://localhost:8000/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Slack OAuth ──────────────────────────────────────────────────────────────
# https://api.slack.com/apps → Create App → OAuth & Permissions
# Add redirect URI: http://localhost:8000/auth/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ─── Hunter.io (optional) ─────────────────────────────────────────────────────
# Free tier: 25 req/month. Leave blank — contact enrichment skips Hunter gracefully.
HUNTER_API_KEY=

# ─── Demo mode ────────────────────────────────────────────────────────────────
# "true" bypasses all API calls and uses built-in mock data. No backend needed.
NEXT_PUBLIC_DEMO_MODE=false
